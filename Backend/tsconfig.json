{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "esModuleInterop": true,
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,        // ✅ req, res, next errors fix
    "strictPropertyInitialization": false  // ✅ class property errors fix
  },
  "exclude": ["node_modules", "dist"]
}